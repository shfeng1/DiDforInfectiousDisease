library(magrittr)
library(dplyr)
library(augsynth)
data <- read.csv("https://dataverse.harvard.edu/api/access/datafile/:persistentId?persistentId=doi:10.7910/DVN/WGWMAV/3UHTLP", sep="\t")
data %>%
filter(!State %in% c("DC", "WI"),
year >= 1959, year <= 1997) %>%
mutate(YearCBrequired = ifelse(is.na(YearCBrequired),
Inf, YearCBrequired),
cbr = 1 * (year >= YearCBrequired)) -> analysis_df
table(data$cbr)
data = data %>%
filter(!State %in% c("DC", "WI"),
year >= 1959, year <= 1997) %>%
mutate(YearCBrequired = ifelse(is.na(YearCBrequired),
Inf, YearCBrequired),
cbr = 1 * (year >= YearCBrequired)) -> analysis_df
table(data$cbr)
table(data$cbr, data$year)
sim.param <- rbind(expand.grid(mean_spe=c(0.8, 1, 1.2), var_spe=1, eff.multi=c(0.8, 1, 1.2)),
expand.grid(mean_spe=1, var_spe=c(0.8, 1.2), eff.multi=c(0.8, 1, 1.2)))
View(sim.param)
sim.param <- expand.grid(trans_prob.base2=1.15/inf_mean, trans_prob.ratio=c(1, 1.1),
eff.multi1=c(0.8, 0.9, 0.95, 1, 1.05, 1.1, 1.2)) %>%
mutate(trans_prob.base1=trans_prob.base2*trans_prob.ratio)
rm(list=ls())
