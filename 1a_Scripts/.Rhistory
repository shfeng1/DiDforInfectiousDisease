inf_mean=10
sim.param <- expand.grid(trans_prob.base2=1.15/inf_mean, trans_prob.ratio=c(1, 1.1),
eff.multi1=c(0.8, 0.9, 0.95, 1, 1.05, 1.1, 1.2)) %>%
mutate(trans_prob.base1=trans_prob.base2*trans_prob.ratio)
